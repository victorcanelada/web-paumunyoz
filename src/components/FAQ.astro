---
const faqs = [
  {
    q: "Com puc demanar cita?",
    a: "Pots demanar cita trucant al 600 07 36 29, omplint el formulari de contacte d'aquesta web o a través del xat de l'assistent virtual. En Pau confirmarà la cita personalment per telèfon."
  },
  {
    q: "Quins serveis oferiu?",
    a: "La consulta ofereix fisioteràpia integral i esportiva, fisio neurogeriàtrica, prevenció de lesions, pressoteràpia, posturologia i atenció a domicili a Mataró i rodalies."
  },
  {
    q: "Quin és l'horari d'atenció?",
    a: "De dilluns a divendres de 15:45 a 21:45, i els dissabtes de 9:00 a 14:00. Els diumenges la consulta és tancada."
  },
  {
    q: "Hi ha aparcament a prop de la consulta?",
    a: "Sí, hi ha el Paurking a menys de 50 metres de la consulta, al Camí de la Geganta, 93 de Mataró."
  },
  {
    q: "Feu visites a domicili?",
    a: "Sí. En Pau atén pacients que no es poden desplaçar a la consulta sense renunciar a la qualitat del tractament. Contacteu per confirmar disponibilitat i zona de cobertura."
  },
  {
    q: "Treballeu amb esportistes d'elit?",
    a: "Sí. La consulta té especialització i experiència en el tractament d'esportistes d'alt rendiment, tant per a lesions agudes com per a prevenció i recuperació funcional."
  },
  {
    q: "Quant costa una sessió?",
    a: "Els preus varien en funció del tractament i es comuniquen personalment. Contacteu sense compromís per rebre informació detallada."
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a }
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section class="faq" id="faq" aria-label="Preguntes freqüents">
  <div class="faq__inner container">

    <div class="faq__header">
      <div data-reveal>
        <span class="eyebrow">Tens dubtes?</span>
      </div>
      <h2 class="faq__title" data-reveal data-delay="1">
        PRE<span class="faq__teal">GUNTES</span>
      </h2>
    </div>

    <div class="faq__list">
      {faqs.map((item, i) => (
        <details class="faq__item" data-reveal data-delay={String((i % 3) + 1)}>
          <summary class="faq__summary">
            <span class="faq__q">{item.q}</span>
            <span class="faq__icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          </summary>
          <p class="faq__answer">{item.a}</p>
        </details>
      ))}
    </div>

  </div>
</section>

<style>
  .faq {
    padding: clamp(5rem, 10vw, 9rem) 0;
    background: var(--off-white);
  }

  .faq__inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .faq__title {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 6vw, 5rem);
    line-height: 0.92;
    color: var(--carbon);
    margin: 1rem 0 0;
  }

  .faq__teal { color: var(--teal); }

  .faq__list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--hairline);
  }

  .faq__item {
    border-bottom: 1px solid var(--hairline);
  }

  .faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.375rem 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq__summary::-webkit-details-marker { display: none; }
  .faq__summary::marker { display: none; }

  .faq__q {
    font-size: 1rem;
    font-weight: 500;
    color: var(--carbon);
    line-height: 1.4;
    transition: color 0.2s;
  }

  .faq__icon {
    flex-shrink: 0;
    color: var(--teal);
    display: flex;
    align-items: center;
    transition: transform 0.35s var(--ease-spring);
  }

  .faq__item[open] .faq__icon { transform: rotate(180deg); }
  .faq__item[open] .faq__q    { color: var(--teal); }

  .faq__answer {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: #777;
    font-weight: 300;
    padding-bottom: 1.5rem;
    max-width: 680px;
  }

  @media (max-width: 768px) {
    .faq__q { font-size: 0.9375rem; }
    .faq__summary { padding: 1.125rem 0; }
  }
</style>
