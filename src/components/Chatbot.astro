---
---
<div class="chat" id="chat-root">
  <button class="chat__trigger" id="chat-trigger" aria-label="Obre el xat" aria-expanded="false" aria-controls="chat-window">
    <svg class="chat__icon chat__icon--open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <svg class="chat__icon chat__icon--close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <div class="chat__window" id="chat-window" role="dialog" aria-modal="false" aria-label="Xat PMF">
    <div class="chat__header" id="chat-header">
      <div class="chat__header-info">
        <div class="chat__avatar" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="10" rx="2"/>
              <circle cx="12" cy="5" r="2"/>
              <path d="M12 7v4"/>
              <circle cx="8.5" cy="16" r="1.5" fill="currentColor" stroke="none"/>
              <circle cx="15.5" cy="16" r="1.5" fill="currentColor" stroke="none"/>
            </svg>
          </div>
        <div>
          <p class="chat__name">Assistent PMF</p>
          <p class="chat__status">En línia · respon en instants</p>
        </div>
      </div>
      <button class="chat__header-close" id="chat-close" aria-label="Tanca el xat">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="chat__messages" id="chat-messages" role="log" aria-live="polite">
      <div class="chat__msg chat__msg--bot">
        <p>Hola Paucient! Soc l'assistent de la consulta d'en Pau Muñoz. En què et puc ajudar?</p>
      </div>
    </div>

    <form class="chat__form" id="chat-form" autocomplete="off">
      <input
        id="chat-input"
        type="text"
        class="chat__input"
        placeholder="Escriu el teu missatge…"
        maxlength="500"
        aria-label="Missatge"
        autocomplete="off"
      />
      <button type="submit" class="chat__send" aria-label="Enviar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </form>
  </div>
</div>

<script>
  const trigger  = document.getElementById('chat-trigger')  as HTMLButtonElement;
  const closeBtn = document.getElementById('chat-header-close') || document.getElementById('chat-close') as HTMLButtonElement;
  const chatWin  = document.getElementById('chat-window')   as HTMLDivElement;
  const messages = document.getElementById('chat-messages') as HTMLDivElement;
  const form     = document.getElementById('chat-form')     as HTMLFormElement;
  const input    = document.getElementById('chat-input')    as HTMLInputElement;

  let isOpen = false;
  let history: { role: 'user' | 'assistant'; content: string }[] = [];

  /* ── Open / close ── */
  function openChat() {
    isOpen = true;
    chatWin.classList.add('chat__window--open');
    trigger.classList.add('chat__trigger--open');
    trigger.setAttribute('aria-expanded', 'true');
    setTimeout(() => input.focus(), 350);
  }

  function closeChat() {
    isOpen = false;
    chatWin.classList.remove('chat__window--open');
    trigger.classList.remove('chat__trigger--open');
    trigger.setAttribute('aria-expanded', 'false');
  }

  function toggleChat() {
    isOpen ? closeChat() : openChat();
  }

  /* ── Shake trigger ── */
  function shakeTrigger() {
    trigger.classList.remove('chat__trigger--shake');
    // Force reflow so animation restarts
    void trigger.offsetWidth;
    trigger.classList.add('chat__trigger--shake');
    trigger.addEventListener('animationend', () => {
      trigger.classList.remove('chat__trigger--shake');
    }, { once: true });
  }

  /* ── Add message bubble ── */
  function addMsg(role: 'user' | 'bot', text: string) {
    const div = document.createElement('div');
    div.className = `chat__msg chat__msg--${role}`;
    const p = document.createElement('p');
    p.textContent = text;
    div.appendChild(p);
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  /* ── Loading indicator ── */
  function setLoading(on: boolean) {
    const id = 'chat-loading';
    if (on) {
      if (document.getElementById(id)) return;
      const div = document.createElement('div');
      div.id = id;
      div.className = 'chat__msg chat__msg--bot chat__msg--loading';
      div.innerHTML = '<span></span><span></span><span></span>';
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    } else {
      document.getElementById(id)?.remove();
    }
  }

  /* ── Send message to API ── */
  async function sendMessage(text: string) {
    addMsg('user', text);
    history.push({ role: 'user', content: text });
    input.disabled = true;
    setLoading(true);

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: history }),
      });
      const data = await res.json();
      const reply = data.text || 'Ho sento, hi ha hagut un error. Truca\'ns si us plau.';
      setLoading(false);
      addMsg('bot', reply);
      history.push({ role: 'assistant', content: reply });
    } catch {
      setLoading(false);
      addMsg('bot', 'Ho sento, hi ha hagut un error de connexió.');
    } finally {
      input.disabled = false;
      input.focus();
    }
  }

  /* ── Global API: called by [data-open-chat] buttons ── */
  (window as any).openChat = function(autoMessage?: string) {
    if (!isOpen) openChat();
    shakeTrigger();

    if (autoMessage) {
      setTimeout(() => sendMessage(autoMessage), 500);
    }
  };

  /* ── Auto-open after 5 s ── */
  setTimeout(() => { if (!isOpen) openChat(); }, 5000);

  /* ── Event listeners ── */
  trigger.addEventListener('click', toggleChat);
  closeBtn?.addEventListener('click', (e) => { e.stopPropagation(); closeChat(); });

  /* Mobile bottom-sheet: tap header to expand/collapse */
  const header = document.getElementById('chat-header') as HTMLDivElement;
  header?.addEventListener('click', () => {
    if (window.innerWidth <= 768) toggleChat();
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    await sendMessage(text);
  });
</script>

<style>
  .chat {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 200;
  }

  /* ── Trigger button ── */
  .chat__trigger {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--carbon);
    color: var(--white);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.22);
    transition: background 0.25s var(--ease-out), transform 0.25s var(--ease-spring);
    flex-shrink: 0;
  }

  .chat__trigger:hover { background: var(--teal); }
  .chat__trigger:active { transform: scale(0.94); }

  /* Icon swap */
  .chat__icon--close { display: none; }
  .chat__trigger--open .chat__icon--open  { display: none; }
  .chat__trigger--open .chat__icon--close { display: block; }

  /* Shake animation */
  @keyframes chat-shake {
    0%,100% { transform: rotate(0deg); }
    15%     { transform: rotate(10deg); }
    30%     { transform: rotate(-10deg); }
    45%     { transform: rotate(7deg); }
    60%     { transform: rotate(-5deg); }
    75%     { transform: rotate(3deg); }
  }

  .chat__trigger--shake {
    animation: chat-shake 0.55s var(--ease-spring);
  }

  /* ── Window ── */
  .chat__window {
    position: absolute;
    bottom: calc(52px + 1rem);
    right: 0;
    width: 340px;
    max-height: 480px;
    background: var(--white);
    border: 1px solid var(--hairline);
    border-radius: 20px;
    box-shadow: 0 12px 48px rgba(0,0,0,0.16);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    /* Hidden state */
    opacity: 0;
    transform: scale(0.94) translateY(10px);
    transform-origin: bottom right;
    pointer-events: none;
    transition:
      opacity   0.3s var(--ease-spring),
      transform 0.35s var(--ease-spring);
  }

  .chat__window--open {
    opacity: 1;
    transform: scale(1) translateY(0);
    pointer-events: auto;
  }

  /* ── Header ── */
  .chat__header {
    padding: 0.875rem 1rem;
    background: var(--carbon);
    color: var(--white);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
    border-radius: 20px 20px 0 0;
  }

  .chat__header-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .chat__avatar {
    background: var(--teal);
    color: var(--carbon);
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .chat__name {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--white);
    line-height: 1.2;
  }

  .chat__status {
    font-size: 0.7rem;
    color: var(--teal);
  }

  .chat__header-close {
    background: none;
    border: none;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    padding: 4px;
    transition: color 0.2s;
  }
  .chat__header-close:hover { color: var(--white); }

  /* ── Messages ── */
  .chat__messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    scroll-behavior: smooth;
  }

  /* :global because these are injected dynamically by JS */
  :global(.chat__msg) { max-width: 88%; }

  :global(.chat__msg p) {
    font-size: 0.9rem;
    line-height: 1.55;
    padding: 0.625rem 0.875rem;
  }

  /* Bot bubble */
  :global(.chat__msg--bot)   { align-self: flex-start; }
  :global(.chat__msg--bot p) {
    background: #F0F0F0;
    color: var(--carbon);
    border-radius: 4px 18px 18px 18px;
  }

  /* User bubble */
  :global(.chat__msg--user)   { align-self: flex-end; }
  :global(.chat__msg--user p) {
    background: var(--teal);
    color: var(--white);
    border-radius: 18px 4px 18px 18px;
  }

  /* Loading dots */
  :global(.chat__msg--loading) {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0.625rem 0.875rem;
    background: var(--off-white);
    align-self: flex-start;
    max-width: 60px;
  }

  :global(.chat__msg--loading span) {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #BBB;
    animation: bounce 1.1s infinite ease-in-out;
  }
  :global(.chat__msg--loading span:nth-child(2)) { animation-delay: 0.18s; }
  :global(.chat__msg--loading span:nth-child(3)) { animation-delay: 0.36s; }

  @keyframes bounce {
    0%, 80%, 100% { transform: scale(0.7); opacity: 0.5; }
    40%            { transform: scale(1);   opacity: 1; }
  }

  /* ── Form ── */
  .chat__form {
    display: flex;
    border-top: 1px solid var(--hairline);
    flex-shrink: 0;
    border-radius: 0 0 20px 20px;
    overflow: hidden;
  }

  .chat__input {
    flex: 1;
    font-family: var(--font-body);
    font-size: 0.9rem;
    border: none;
    outline: none;
    padding: 0.875rem 1rem;
    color: var(--carbon);
    background: var(--white);
  }
  .chat__input::placeholder { color: #C0C0C0; }

  .chat__send {
    background: none;
    border: none;
    padding: 0.875rem 1rem;
    color: var(--carbon);
    cursor: pointer;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }
  .chat__send:hover { color: var(--teal); }

  @media (max-width: 400px) {
    .chat__window { width: calc(100vw - 3rem); }
    .chat { right: 1rem; bottom: 1rem; }
  }

  /* ── Mobile: bottom-sheet drawer ── */
  @media (max-width: 768px) {
    .chat__trigger { display: none; }

    .chat__window {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      width: 100%;
      max-height: 92svh;
      border-radius: 20px 20px 0 0;
      transform-origin: bottom center;
      /* override desktop hidden state — always peeking */
      opacity: 1;
      pointer-events: auto;
      transform: translateY(calc(100% - 60px));
      transition: transform 0.45s var(--ease-spring);
    }

    .chat__window--open {
      transform: translateY(0);
    }

    .chat__header {
      border-radius: 20px 20px 0 0;
      cursor: pointer;
      user-select: none;
    }
  }
</style>
