---
---
<header class="navbar" id="main-nav" role="banner">
  <div class="navbar__pill">
    <a href="#hero" class="navbar__logo" aria-label="PMF – Pau Muñoz Fisioteràpia">
      <svg width="36" height="36" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="50" cy="50" r="50" fill="#2B2B2B"/>
        <text x="9" y="67" font-family="Arial Black,sans-serif" font-size="46" font-weight="900" fill="white">PM</text>
        <text x="68" y="67" font-family="Arial Black,sans-serif" font-size="46" font-weight="900" fill="#5BBFD1">F</text>
      </svg>
    </a>

    <nav class="navbar__links" aria-label="Navegació principal">
      <a href="#serveis"   class="navbar__link">Serveis</a>
      <a href="#paucients" class="navbar__link">Paucients</a>
      <a href="#contacte"  class="navbar__link">Contacte</a>
    </nav>

    <a href="#" class="navbar__cta" data-open-chat="Hola! Vull demanar una cita">
      <span>DEMANAR CITA</span>
      <span class="navbar__cta-dot" aria-hidden="true"></span>
    </a>

    <button class="navbar__burger" id="nav-burger" aria-label="Obre el menú" aria-expanded="false" aria-controls="nav-overlay">
      <span class="navbar__burger-bar"></span>
      <span class="navbar__burger-bar"></span>
    </button>
  </div>
</header>

<!-- Full-screen mobile overlay -->
<div class="nav-overlay" id="nav-overlay" aria-hidden="true">
  <nav class="nav-overlay__links" aria-label="Menú mòbil">
    <a href="#serveis"   class="nav-overlay__link" data-overlay-link>Serveis</a>
    <a href="#paucients" class="nav-overlay__link" data-overlay-link>Paucients</a>
    <a href="#contacte"  class="nav-overlay__link" data-overlay-link>Contacte</a>
  </nav>
  <a href="#" class="nav-overlay__cta" data-overlay-link data-open-chat="Hola! Vull demanar una cita">DEMANAR CITA</a>
</div>

<script>
  const burger  = document.getElementById('nav-burger') as HTMLButtonElement;
  const overlay = document.getElementById('nav-overlay') as HTMLDivElement;

  let open = false;

  function toggle() {
    open = !open;
    burger.setAttribute('aria-expanded', String(open));
    overlay.setAttribute('aria-hidden', String(!open));
    burger.classList.toggle('navbar__burger--open', open);
    overlay.classList.toggle('nav-overlay--open', open);
    document.body.style.overflow = open ? 'hidden' : '';
  }

  burger.addEventListener('click', toggle);

  document.querySelectorAll('[data-overlay-link]').forEach(link => {
    link.addEventListener('click', () => { if (open) toggle(); });
  });
</script>

<style>
  /* ── Floating pill ── */
  .navbar {
    position: fixed;
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 90;
    width: max-content;
    max-width: calc(100vw - 2.5rem);
    transition: top 0.4s var(--ease-spring);
  }

  .navbar--scrolled .navbar__pill {
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 2px 32px rgba(0,0,0,0.1);
  }

  .navbar__pill {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    background: var(--white);
    border: 1px solid var(--hairline);
    border-radius: 999px;
    padding: 0.5rem 0.5rem 0.5rem 1rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
    transition: background 0.4s, box-shadow 0.4s;
  }

  .navbar__logo { display: flex; align-items: center; flex-shrink: 0; }

  /* ── Links ── */
  .navbar__links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .navbar__link {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--carbon);
    position: relative;
    padding-bottom: 1px;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--teal);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease-spring);
  }

  .navbar__link:hover::after { transform: scaleX(1); }

  /* ── CTA ── */
  .navbar__cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--carbon);
    color: var(--white);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.625rem 1.25rem;
    border-radius: 999px;
    transition: background 0.25s var(--ease-out);
    flex-shrink: 0;
  }

  .navbar__cta:hover { background: var(--teal); }

  .navbar__cta-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal);
    flex-shrink: 0;
    transition: background 0.25s;
  }

  .navbar__cta:hover .navbar__cta-dot { background: var(--white); }

  /* ── Burger ── */
  .navbar__burger {
    display: none;
    flex-direction: column;
    gap: 6px;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
  }

  .navbar__burger-bar {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--carbon);
    border-radius: 2px;
    transform-origin: center;
    transition: transform 0.35s var(--ease-spring), opacity 0.2s;
  }

  .navbar__burger--open .navbar__burger-bar:nth-child(1) { transform: translateY(3.75px) rotate(45deg); }
  .navbar__burger--open .navbar__burger-bar:nth-child(2) { transform: translateY(-3.75px) rotate(-45deg); }

  /* ── Overlay ── */
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 80;
    background: var(--carbon);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: 2rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s var(--ease-out);
  }

  .nav-overlay--open {
    opacity: 1;
    pointer-events: auto;
  }

  .nav-overlay__links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 3rem;
  }

  .nav-overlay__link {
    font-family: var(--font-display);
    font-size: clamp(3rem, 12vw, 5rem);
    color: var(--white);
    line-height: 1.05;
    transition: color 0.2s;
  }

  .nav-overlay__link:hover { color: var(--teal); }

  .nav-overlay__cta {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--teal);
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--teal);
    padding-bottom: 2px;
  }

  @media (max-width: 768px) {
    .navbar { width: calc(100vw - 2.5rem); }
    .navbar__pill { padding: 0.4rem 0.4rem 0.4rem 0.875rem; gap: 0.75rem; }
    .navbar__links { display: none; }
    .navbar__cta {
      margin-left: auto;
      font-size: 0.7rem;
      padding: 0.5rem 0.875rem;
      letter-spacing: 0.07em;
    }
    .navbar__cta-dot { display: none; }
    .navbar__burger { display: flex; }
  }
</style>
